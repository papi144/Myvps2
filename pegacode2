// ========== DEVICE DETECTION ==========
void detect_device() {
    struct utsname u;
    if (uname(&u) == 0) {
        printf("[*] Kernel: %s %s %s\n", u.sysname, u.release, u.machine);
        sscanf(u.release, "%d.%d", &kernel_version_major, &kernel_version_minor);
        
        if (strstr(u.machine, "x86_64") || strstr(u.machine, "amd64")) {
            is_x86_64 = 1;
        }
    }
    
    FILE *f = fopen("/system/build.prop", "r");
    if (f) {
        char line[256];
        while (fgets(line, sizeof(line), f)) {
            if (strstr(line, "ro.product.model")) {
                char *p = strchr(line, '=');
                if (p) {
                    strncpy(detected_device, p + 1, sizeof(detected_device) - 1);
                    detected_device[strlen(detected_device) - 1] = 0;
                }
            }
        }
        fclose(f);
    }
    
    if (strstr(detected_device, "Samsung") || strstr(detected_device, "samsung")) {
        has_knox = 1;
        mitigations_active |= MITIGATIONS_KNOX;
    }
    
    printf("[*] Device: %s\n", detected_device);
    printf("[*] Architecture: %s\n", is_x86_64 ? "x86_64" : "ARM64");
    printf("[*] Kernel: %d.%d\n", kernel_version_major, kernel_version_minor);
    printf("[*] KNOX: %s\n", has_knox ? "YES" : "NO");
}

